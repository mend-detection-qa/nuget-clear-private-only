# Mend Unified Agent config -- NuGet resolver tuning for the <clear/> repro.
#
# This file is read on the Mend for Azure Repos SCA path. The properties below
# are the levers the customer can pull to force the scanner to honor an
# in-repo nuget.config and stop appending nuget.org.
#
# Leave fileSystemScan on; the resolver-level toggles are what matter.

checkPolicies=false
forceCheckAllDependencies=false
forceUpdate=true
forceUpdate.failBuildOnPolicyViolation=false
offline=false

fileSystemScan=true
resolveAllDependencies=false

# ---- NuGet ----
nuget.resolveDependencies=true
nuget.restoreDependencies=true

# Prefer `dotnet restore` over the legacy `nuget.exe` path. `dotnet restore`
# is the path that honors the in-repo nuget.config most consistently. If the
# customer's scan logs show `nuget.exe` being invoked, that path has historically
# been more aggressive about appending nuget.org.
nuget.preferredEnvironment=dotnet

# Newer flag (UA 24.x+): tells the resolver to read the customer's nuget.config
# verbatim and NOT inject a fallback source. If your UA version doesn't recognize
# this key it is a no-op (safe to leave).
nuget.resolveNugetConfigs=true

# Run `dotnet restore` once before resolution so project.assets.json exists
# at scan time. The dep tree is then read from the lockfile rather than
# re-resolved by the scanner -- closes the door on any source-injection.
nuget.runPreStep=true

# Do NOT let the resolver invent its own NuGet.config in a temp dir.
# (Field name varies by UA version; both spellings are accepted by the parser.)
nuget.ignoreSourceFiles=false
nuget.includeDevDependencies=false

includes=**/*.csproj **/*.fsproj **/*.vbproj **/packages.config **/project.assets.json
excludes=**/node_modules/** **/bin/** **/obj/debug/**
case.sensitive.glob=false
followSymbolicLinks=false