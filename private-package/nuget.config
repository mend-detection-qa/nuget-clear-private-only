<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Producer-local config. The consumer-side nuget.config one directory up
    uses <clear/> + GitHub Packages as the only source; that is intentional
    for the scan experiment but it would block the producer's own restore
    of NETStandard.Library and friends.

    This file overrides the parent for the producer build only: <clear/>
    drops the parent's source list, then we re-add nuget.org explicitly.
    The Mend scan of the consumer does NOT read this file, so the experiment
    is unaffected.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>