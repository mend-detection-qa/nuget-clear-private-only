{
  "scanSettings": {
    "configMode": "AUTO",
    "configExternalURL": "",
    "enableLicenseViolations": "true",
    "projectToken": "",
    "baseBranches": [],
    "exploitability": true
  },
  "hostRules": [
    {
      "matchHost": "https://nexus.mendinfra.com/repository/dotnet-feed/",
      "username": "mend-qa",
      "hostType": "nuget",
      "encrypted": {
        "password": ""
      }
    }
  ],
  "checkRunSettings": {
    "vulnerableCheckRunConclusionLevel": "failure",
    "licenseCheckRunConclusionLevel": "failure",
    "useMendCheckNames": true,
    "showWsInfo": true,
    "displayMode": "diff",
    "strictMode": "failure"
  },
  "pullRequestStatusSettings": {
    "vulnerablePullRequestStatus": "failed",
    "displayMode": "diff",
    "useMendStatusNames": true
  },
  "issueSettings": {
    "minSeverityLevel": "LOW",
    "issueType": "DEPENDENCY",
    "displayLicenseViolations": "true"
  }
}






