<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!--
    Customer-intent shape: <clear/> wipes any inherited sources (machine-wide,
    user-level, or appended by tooling), then ONLY the private feed remains.
    A NuGet client that honors this config must resolve EVERY package
    (direct + transitive) from `private` and never fall through to nuget.org.

    The bug the customer reports: a Mend SCA scan resolves packages from
    nuget.org anyway, implying Mend appended its own source AFTER reading
    this file (or ignored the <clear/> altogether).
  -->
  <packageSources>
    <clear />
    <add key="private" value="https://nuget.pkg.github.com/mend-detection-qa/index.json" />
  </packageSources>

  <!--
    GitHub Packages requires auth even for read. For the scan side we
    intentionally leave credentials OUT of this file. A failed restore
    still produces the source-list log lines we need to answer the question.
    If you later want restore to succeed (cleaner dep tree in Mend UI),
    flip the repo to PRIVATE and uncomment the block below with a read-only
    PAT injected via env vars.
  -->
  <!--
  <packageSourceCredentials>
    <private>
      <add key="Username" value="%MEND_GHP_USER%" />
      <add key="ClearTextPassword" value="%MEND_GHP_PAT%" />
    </private>
  </packageSourceCredentials>
  -->

  <config>
    <!-- Local restore directory; off the repo root by default. -->
    <add key="globalPackagesFolder" value=".nuget-packages" />
  </config>

  <!--
    Disables NuGet's automatic source fallback. Some Mend / dotnet versions
    consult this. Leaving here as a defense-in-depth marker for the repro.
  -->
  <fallbackPackageFolders>
    <clear />
  </fallbackPackageFolders>

</configuration>